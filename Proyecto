#include <HardwareSerial.h>
#include <TinyGPSPlus.h>
#include <BluetoothSerial.h>
#include <WiFi.h>
#include <HTTPClient.h>
#include <ArduinoJson.h>
#include <Wire.h>
#include <Adafruit_Sensor.h>
#include <Adafruit_BME680.h>

const char* WIFI_SSID     = "_HIRALDA_";
const char* WIFI_PASSWORD = "**2004##25__";

// Token del dispositivo en Tago.io (Dashboard → Devices → Token)
const char* TAGO_TOKEN    = "132d7a07-4c99-4130-aab5-974e71ae2582";
const char* TAGO_URL      = "https://api.tago.io/data";

// Nombre Bluetooth visible desde App Inventor
const char* BT_NOMBRE     = "ESP_Carlinhox";

// Intervalo de envío a Tago.io (ms)
const unsigned long INTERVALO_TAGO = 15000;   // 15 segundos

// Pines GPS (UART2)
const int GPS_RX_PIN = 16;   // ← NEO-6M TX
const int GPS_TX_PIN = 17;   // → NEO-6M RX

// Dirección I2C del BME680 (0x76 si SDO→GND, 0x77 si SDO→3.3V)
#define BME680_ADDR  0x76

// Ecuador = UTC-5 (no tiene horario de verano)
const int UTC_OFFSET_HORAS = -5;

// Presión al nivel del mar para cálculo de altitud barométrica
#define PRESION_MAR_HPA  1013.25f
/* ────────────────────────────────────────── */

TinyGPSPlus      gps;
HardwareSerial   serialGPS(2);
BluetoothSerial  btSerial;
Adafruit_BME680  bme;

/* ── Variables GPS ── */
double  latitud    = 0.0;
double  longitud   = 0.0;
double  altitudGPS = 0.0;
double  velocidad  = 0.0;
int     satelites  = 0;
double  hdop       = 99.9;
bool    gpsValido  = false;

/* ── Hora Ecuador ── */
int horaEC = 0, minEC = 0, segEC = 0;
int diaEC  = 0, mesEC = 0, anioEC = 0;

/* ── Variables BME680 ── */
float  temperatura  = 0.0;   // °C
float  humedad      = 0.0;   // %
float  presion      = 0.0;   // hPa
float  gasResist    = 0.0;   // kΩ
float  altitudBME   = 0.0;   // m (calculada desde presión)
bool   bmeOK        = false;

unsigned long ultimoEnvioTago = 0;

// ══════════════════════════════════════════
void setup() {
  Serial.begin(115200);
  delay(500);

  Serial.println("=========================================");
  Serial.println("  ESP32 + NEO-6M + BME680  — v2.0");
  Serial.println("  Zona horaria: Ecuador (UTC-5)");
  Serial.println("=========================================");

  // ── GPS UART2 ──
  serialGPS.begin(9600, SERIAL_8N1, GPS_RX_PIN, GPS_TX_PIN);
  Serial.println("[GPS]  UART2 iniciado a 9600 baud");

  // ── BME680 I2C ──
  Wire.begin();   // SDA=21, SCL=22 (por defecto en ESP32)
  if (bme.begin(BME680_ADDR)) {
    bmeOK = true;
    bme.setTemperatureOversampling(BME680_OS_8X);
    bme.setHumidityOversampling(BME680_OS_2X);
    bme.setPressureOversampling(BME680_OS_4X);
    bme.setIIRFilterSize(BME680_FILTER_SIZE_3);
    bme.setGasHeater(320, 150);   // 320 °C, 150 ms
    Serial.println("[BME]  BME680 listo (I2C 0x" + String(BME680_ADDR, HEX) + ")");
  } else {
    Serial.println("[BME]  ERROR: BME680 no encontrado.");
    Serial.println("[BME]  Verifica pines SDA/SCL y dirección SDO.");
    Serial.println("[BME]  Continuando sin sensor ambiental...");
  }

  // ── Bluetooth ──
  if (!btSerial.begin(BT_NOMBRE)) {
    Serial.println("[BT]   Error al iniciar Bluetooth");
  } else {
    Serial.println("[BT]   Listo como: " + String(BT_NOMBRE));
  }

  // ── WiFi ──
  conectarWiFi();
}

// ══════════════════════════════════════════
void loop() {
  leerGPS();
  leerBME680();

  if (btSerial.hasClient()) {
    enviarBluetooth();
  }

  imprimirSerial();

  if (millis() - ultimoEnvioTago >= INTERVALO_TAGO) {
    if (WiFi.status() != WL_CONNECTED) conectarWiFi();
    if (WiFi.status() == WL_CONNECTED) enviarTago();
    ultimoEnvioTago = millis();
  }

  delay(1000);
}

void convertirHoraEcuador(int hUTC, int mUTC, int sUTC,
                           int dUTC, int moUTC, int aUTC) {
  int totalMin = hUTC * 60 + mUTC + UTC_OFFSET_HORAS * 60;
  int diaOffset = 0;

  if (totalMin < 0) {
    totalMin += 1440;
    diaOffset = -1;
  } else if (totalMin >= 1440) {
    totalMin -= 1440;
    diaOffset = +1;
  }

  horaEC = totalMin / 60;
  minEC  = totalMin %% 60;
  segEC  = sUTC;

  diaEC  = dUTC  + diaOffset;
  mesEC  = moUTC;
  anioEC = aUTC;

  // Corrección de desbordamiento de día
  if (diaEC < 1) {
    mesEC--;
    if (mesEC < 1) { mesEC = 12; anioEC--; }
    int diasMes[] = {0,31,28,31,30,31,30,31,31,30,31,30,31};
    bool bisiesto = (anioEC % 4 == 0 && (anioEC % 100 != 0 || anioEC % 400 == 0));
    if (bisiesto) diasMes[2] = 29;
    diaEC = diasMes[mesEC];
  } else if (diaEC > 31) {
    diaEC = 1;
    mesEC++;
    if (mesEC > 12) { mesEC = 1; anioEC++; }
  }
}

// ──────────────────────────────────────────
// Lee y parsea datos del GPS
// ──────────────────────────────────────────
void leerGPS() {
  unsigned long inicio = millis();
  while (millis() - inicio < 950) {
    while (serialGPS.available()) {
      gps.encode(serialGPS.read());
    }
  }

  if (gps.location.isUpdated()) {
    latitud   = gps.location.lat();
    longitud  = gps.location.lng();
    gpsValido = gps.location.isValid();
  }
  if (gps.altitude.isUpdated())   altitudGPS = gps.altitude.meters();
  if (gps.speed.isUpdated())      velocidad  = gps.speed.kmph();
  if (gps.satellites.isUpdated()) satelites  = gps.satellites.value();
  if (gps.hdop.isUpdated())       hdop       = gps.hdop.hdop();

  if (gps.time.isValid() && gps.date.isValid()) {
    convertirHoraEcuador(
      gps.time.hour(), gps.time.minute(), gps.time.second(),
      gps.date.day(),  gps.date.month(),  gps.date.year()
    );
  }
}

void leerBME680() {
  if (!bmeOK) return;

  if (!bme.performReading()) {
    Serial.println("[BME]  Fallo en la lectura");
    return;
  }

  temperatura = bme.temperature;
  humedad     = bme.humidity;
  presion     = bme.pressure / 100.0F;          // Pa → hPa
  gasResist   = bme.gas_resistance / 1000.0F;   // Ω  → kΩ
  altitudBME  = 44330.0f * (1.0f - pow(presion / PRESION_MAR_HPA, 0.1903f));
}

// App Inventor: split(texto, ",") → lista de 13 elementos (índices 1-13)
//   1=Lat  2=Lon  3=AltGPS  4=Vel  5=Sat  6=HDOP
//   7=Hora  8=Fecha
//   9=Temp  10=Hum  11=Pres  12=Gas  13=AltBME
// ──────────────────────────────────────────
void enviarBluetooth() {
  String d = "";

  // GPS
  if (gpsValido) {
    d += String(latitud,    6) + ",";
    d += String(longitud,   6) + ",";
    d += String(altitudGPS, 1) + ",";
    d += String(velocidad,  1) + ",";
    d += String(satelites)     + ",";
    d += String(hdop,       1) + ",";
  } else {
    d += "0,0,0,0,0,99.9,";
  }

  // Hora y fecha Ecuador
  char buf[25];
  snprintf(buf, sizeof(buf), "%02d:%02d:%02d", horaEC, minEC, segEC);
  d += String(buf) + ",";
  snprintf(buf, sizeof(buf), "%02d/%02d/%04d", diaEC, mesEC, anioEC);
  d += String(buf) + ",";

  // BME680
  if (bmeOK) {
    d += String(temperatura, 1) + ",";
    d += String(humedad,     1) + ",";
    d += String(presion,     1) + ",";
    d += String(gasResist,   1) + ",";
    d += String(altitudBME,  1);
  } else {
    d += "0,0,0,0,0";
  }

  d += "\n";
  btSerial.print(d);
}

// ──────────────────────────────────────────
// Envía datos a Tago.io vía HTTPS REST API
// ──────────────────────────────────────────
void enviarTago() {
  HTTPClient http;
  http.begin(TAGO_URL);
  http.addHeader("Content-Type", "application/json");
  http.addHeader("Device-Token", TAGO_TOKEN);

  StaticJsonDocument<1024> doc;
  JsonArray array = doc.to<JsonArray>();

  // Lambda helper para agregar variables numéricas
  auto addVar = [&](const char* var, float val, const char* unit = nullptr) {
    JsonObject obj = array.createNestedObject();
    obj["variable"] = var;
    obj["value"]    = val;
    if (unit) obj["unit"] = unit;
  };

  // ── GPS ──
  JsonObject loc    = array.createNestedObject();
  loc["variable"]   = "location";
  JsonObject locVal = loc.createNestedObject("value");
  locVal["lat"]     = latitud;
  locVal["lng"]     = longitud;

  addVar("altitud_gps", altitudGPS, "m");
  addVar("velocidad",   velocidad,  "km/h");
  addVar("satelites",   satelites);
  addVar("hdop",        hdop);

  // ── Hora Ecuador ──
  char fechaHora[22];
  snprintf(fechaHora, sizeof(fechaHora), "%02d/%02d/%04d %02d:%02d:%02d",
           diaEC, mesEC, anioEC, horaEC, minEC, segEC);
  JsonObject horaObj  = array.createNestedObject();
  horaObj["variable"] = "hora_ecuador";
  horaObj["value"]    = fechaHora;

  // ── BME680 ──
  if (bmeOK) {
    addVar("temperatura", temperatura, "°C");
    addVar("humedad",     humedad,     "%");
    addVar("presion",     presion,     "hPa");
    addVar("gas_resist",  gasResist,   "kΩ");
    addVar("altitud_bme", altitudBME,  "m");
  }

  String cuerpo;
  serializeJson(doc, cuerpo);

  int httpCode = http.POST(cuerpo);
  if (httpCode == HTTP_CODE_OK || httpCode == 201) {
    Serial.println("[Tago] Enviado OK — HTTP " + String(httpCode));
  } else {
    Serial.println("[Tago] Error HTTP " + String(httpCode) + ": " + http.getString());
  }

  http.end();
}

// ──────────────────────────────────────────
// Conectar WiFi
// ──────────────────────────────────────────
void conectarWiFi() {
  Serial.print("[WiFi] Conectando a " + String(WIFI_SSID));
  WiFi.begin(WIFI_SSID, WIFI_PASSWORD);
  int intentos = 0;
  while (WiFi.status() != WL_CONNECTED && intentos < 20) {
    delay(500); Serial.print("."); intentos++;
  }
  if (WiFi.status() == WL_CONNECTED) {
    Serial.println("\n[WiFi] IP: " + WiFi.localIP().toString());
  } else {
    Serial.println("\n[WiFi] Sin conexión.");
  }
}

// ──────────────────────────────────────────
// Monitor Serial
// ──────────────────────────────────────────
void imprimirSerial() {
  Serial.println("─────────────────────────────────────────");

  if (gpsValido) {
    Serial.printf("Lat/Lon:   %.6f, %.6f\n", latitud, longitud);
    Serial.printf("Alt GPS:   %.1f m\n",     altitudGPS);
    Serial.printf("Velocidad: %.1f km/h  |  Sat: %d  |  HDOP: %.1f\n",
                  velocidad, satelites, hdop);
  } else {
    Serial.println("GPS: esperando señal... (" +
                   String(gps.charsProcessed()) + " chars)");
  }

  Serial.printf("Hora ECU:  %02d:%02d:%02d  |  Fecha: %02d/%02d/%04d\n",
                horaEC, minEC, segEC, diaEC, mesEC, anioEC);

  if (bmeOK) {
    Serial.printf("Temp:      %.1f °C\n",  temperatura);;
    Serial.printf("Humedad:   %.1f %%\n",  humedad);
    Serial.printf("Presión:   %.1f hPa\n", presion);
    Serial.printf("Gas:       %.1f kΩ\n",  gasResist);
    Serial.printf("Alt BME:   %.1f m\n",   altitudBME);
  } else {
    Serial.println("BME680:    no disponible");
  }

  Serial.println("BT: " + String(btSerial.hasClient() ? "Cliente conectado" : "Esperando"));
  Serial.println("WiFi: " + String(WiFi.status() == WL_CONNECTED ?
                 WiFi.localIP().toString() : "Desconectado"));
}