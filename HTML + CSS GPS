<script>
/* ══════════════════════════════════════════
   VARIABLES TAGO — deben coincidir
   exactamente con tu código Arduino
══════════════════════════════════════════ */
const V_LAT  = "latitud";
const V_LNG  = "longitud";
const V_ALT  = "altitud";
const V_SPD  = "velocidad";
const V_SAT  = "satelites";
const V_DATE = "fecha_ec";
const V_TIME = "hora_ec";

const INTERVAL = 3000; // ms — actualización cada 3 s

/* ── DOM ── */
const modalOverlay = document.getElementById("modalOverlay");
const tokenInp     = document.getElementById("tokenInp");
const eyeBtn       = document.getElementById("eyeBtn");
const connBtn      = document.getElementById("connBtn");
const modalErr     = document.getElementById("modalErr");
const chgBtn       = document.getElementById("chgBtn");
const lastTime     = document.getElementById("lastTime");
const tagoStatus   = document.getElementById("tagoStatus");

let TOKEN    = "";
let pollTimer = null;

/* ── Estrellas en canvas ── */
(function initStars(){
  const c  = document.getElementById("stars");
  const ctx = c.getContext("2d");
  c.width  = window.innerWidth;
  c.height = window.innerHeight;
  for(let i=0;i<200;i++){
    const x = Math.random()*c.width;
    const y = Math.random()*c.height;
    const r = Math.random()*1.2+.2;
    ctx.beginPath();
    ctx.arc(x,y,r,0,Math.PI*2);
    ctx.fillStyle = `rgba(255,255,255,${Math.random()*.7+.1})`;
    ctx.fill();
  }
})();

/* ── Modal ── */
eyeBtn.addEventListener("click", ()=>{
  tokenInp.type = tokenInp.type==="password" ? "text" : "password";
});
tokenInp.addEventListener("keydown", e=>{ if(e.key==="Enter") connBtn.click(); });

connBtn.addEventListener("click", async ()=>{
  const t = tokenInp.value.trim();
  if(!t){ modalErr.textContent="Ingresa el token."; return; }
  modalErr.textContent="";
  connBtn.textContent="Verificando…";
  connBtn.disabled=true;
  const ok = await testToken(t);
  connBtn.textContent="CONECTAR";
  connBtn.disabled=false;
  if(ok){
    TOKEN = t;
    localStorage.setItem("gps_token", t);
    modalOverlay.style.display="none";
    startPolling();
  } else {
    modalErr.textContent="❌ Token inválido. Verifica en Tago.io.";
  }
});

chgBtn.addEventListener("click", ()=>{
  clearInterval(pollTimer);
  tokenInp.value = TOKEN;
  modalOverlay.style.display="flex";
});

async function testToken(t){
  try{
    const r = await fetch(`https://api.tago.io/data?variable=${V_LAT}&qty=1`,
                          {headers:{"Device-Token":t}});
    if(!r.ok) return false;
    const j = await r.json();
    return j.status === true;
  }catch{ return false; }
}

/* ── Fetch variable Tago ── */
async function fetchVar(v){
  const r = await fetch(`https://api.tago.io/data?variable=${v}&qty=1`,
                        {headers:{"Device-Token":TOKEN}});
  if(!r.ok) throw new Error(`HTTP ${r.status}`);
  const j = await r.json();
  return (j.result && j.result.length) ? j.result[0].value : null;
}

/* ════════════════════════════
   UPDATE UI
════════════════════════════ */
function updateUI(lat, lng, alt, spd, sat, dateStr, timeStr){
  lastTime.textContent   = new Date().toLocaleTimeString("es-EC");
  tagoStatus.textContent = "● CONECTADO";
  tagoStatus.style.color = "var(--green)";

  /* ── LATITUD (rango útil GPS -90 a +90) ── */
  if(lat !== null){
    const v = parseFloat(lat);
    document.getElementById("latVal").innerHTML =
      `${v.toFixed(4)}<span class="u">°</span>`;
    // Barra 0-100% mapeado de -90 a +90
    const pct = ((v + 90) / 180) * 100;
    document.getElementById("latBar").style.width = pct + "%";
    // Aguja globo: -90°=girado, 0°=centro, +90°=opuesto
    const ang = (v / 90) * 80; // ±80° de rotación visual
    document.getElementById("latNeedle").style.transform =
      `translateX(-50%) rotate(${ang}deg)`;
    document.getElementById("latStatus").textContent =
      v > 0 ? `${v.toFixed(4)}° Norte` : v < 0 ? `${Math.abs(v).toFixed(4)}° Sur` : "Ecuador (0°)";
  }

  /* ── LONGITUD (-180 a +180) ── */
  if(lng !== null){
    const v = parseFloat(lng);
    document.getElementById("lngVal").innerHTML =
      `${v.toFixed(4)}<span class="u">°</span>`;
    const pct = ((v + 180) / 360) * 100;
    document.getElementById("lngBar").style.width = pct + "%";
    // Punto en el anillo de Saturno
    const angle = ((v + 180) / 360) * Math.PI * 2 - Math.PI/2;
    const rx = 70, ry = 16, cx = 90, cy = 68;
    const dx = cx + rx * Math.cos(angle);
    const dy = cy + ry * Math.sin(angle);
    const dot = document.getElementById("lngDot");
    dot.setAttribute("cx", dx.toFixed(1));
    dot.setAttribute("cy", dy.toFixed(1));
    document.getElementById("lngStatus").textContent =
      v >= 0 ? `${v.toFixed(4)}° Este` : `${Math.abs(v).toFixed(4)}° Oeste`;
  }

  /* ── ALTITUD (0–6000 m) ── */
  if(alt !== null){
    const v = parseFloat(alt);
    document.getElementById("altVal").innerHTML =
      `${Math.round(v).toLocaleString("es-EC")}<span class="u">m</span>`;
    const pct = Math.min(100, Math.max(0, v / 6000 * 100));
    // Barra vertical en el SVG (120 px de alto, de abajo hacia arriba)
    const barH = (pct / 100) * 120;
    const barY  = 140 - barH;
    const bar = document.getElementById("altBarRect");
    bar.setAttribute("height", barH);
    bar.setAttribute("y", barY);
    document.getElementById("altStatus").textContent =
      v < 500  ? "Nivel bajo 🌊" :
      v < 1500 ? "Valle 🌄"      :
      v < 3000 ? "Montaña ⛰"    :
      v < 5000 ? "Alta montaña 🏔" : "Cima 🗻";
  }

  /* ── VELOCIDAD (0–200 km/h) ── */
  if(spd !== null){
    const v = parseFloat(spd);
    const vRound = Math.round(v * 10) / 10;
    document.getElementById("spdVal").innerHTML =
      `${vRound}<span class="u">km/h</span>`;
    document.getElementById("spdCenterVal").textContent = Math.round(v);
    // Arco: 211px de circunferencia total (semicírculo)
    const pct = Math.min(100, v / 200 * 100);
    const offset = 211 - (pct / 100) * 211;
    document.getElementById("spdArc").style.strokeDashoffset = offset;
    // Aguja: de -90° (0) a +90° (200)
    const ang = -90 + (pct / 100) * 180;
    document.getElementById("spdNeedle").style.transform = `rotate(${ang}deg)`;
    document.getElementById("spdStatus").textContent =
      v < 1   ? "Detenido 🛑" :
      v < 30  ? "Lento 🐢"   :
      v < 80  ? "Normal 🚗"  :
      v < 140 ? "Rápido 💨"  : "¡Máxima velocidad! 🏎";
  }

  /* ── SATÉLITES (0–12) ── */
  if(sat !== null){
    const v = parseInt(sat);
    document.getElementById("satVal").innerHTML =
      `${v}<span class="u">SAT</span>`;
    document.getElementById("satBar").style.width = Math.min(100, v / 12 * 100) + "%";
    document.getElementById("satStatus").textContent =
      v === 0 ? "Sin señal ❌" :
      v < 4   ? "Señal débil ⚠️" :
      v < 8   ? "Señal buena ✅" : "Señal excelente 🛰";
    // Dibujar puntos satélite
    const g = document.getElementById("satDots");
    g.innerHTML = "";
    for(let i=0;i<12;i++){
      const active = i < v;
      const cx = 15 + (i % 6) * 20;
      const cy = Math.floor(i / 6) * 14;
      const dot = document.createElementNS("http://www.w3.org/2000/svg","circle");
      dot.setAttribute("cx", cx);
      dot.setAttribute("cy", cy);
      dot.setAttribute("r", "5");
      dot.setAttribute("fill", active ? "#00ff88" : "#1a2a4a");
      if(active){
        dot.setAttribute("filter","url(#satGlow)");
      }
      g.appendChild(dot);
    }
  }

  /* ── FECHA ── */
  if(dateStr !== null){
    document.getElementById("fechaVal").textContent = dateStr;
  }

  /* ── HORA + RELOJ ── */
  if(timeStr !== null){
    document.getElementById("horaVal").textContent = timeStr;
    // Parsear hh:mm:ss
    const parts = String(timeStr).split(":");
    if(parts.length === 3){
      const h = parseInt(parts[0]) % 12;
      const m = parseInt(parts[1]);
      const s = parseInt(parts[2]);
      const angH = (h / 12) * 360 + (m / 60) * 30;
      const angM = (m / 60) * 360 + (s / 60) * 6;
      const angS = (s / 60) * 360;
      document.getElementById("clockH").style.transform = `rotate(${angH}deg)`;
      document.getElementById("clockM").style.transform = `rotate(${angM}deg)`;
      document.getElementById("clockS").style.transform = `rotate(${angS}deg)`;
    }
  }
}

/* ── Poll Tago ── */
async function poll(){
  try{
    const [lat, lng, alt, spd, sat, dateStr, timeStr] = await Promise.all([
      fetchVar(V_LAT), fetchVar(V_LNG), fetchVar(V_ALT),
      fetchVar(V_SPD), fetchVar(V_SAT), fetchVar(V_DATE), fetchVar(V_TIME)
    ]);
    updateUI(lat, lng, alt, spd, sat, dateStr, timeStr);
  } catch(e){
    tagoStatus.textContent = "● ERROR CONEXIÓN";
    tagoStatus.style.color = "var(--red)";
    console.error("Tago:", e);
  }
}

function startPolling(){
  poll();
  pollTimer = setInterval(poll, INTERVAL);
}

/* ── Cargar token guardado ── */
window.addEventListener("load", ()=>{
  const saved = localStorage.getItem("gps_token");
  if(saved) tokenInp.value = saved;
