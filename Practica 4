/*
   ESP32 + BME680 + TAGO.IO
   Envía:
   - temperature
   - humidity
   - pressure
   - altitude
   - gas_resistance
*/

#include <WiFi.h>
#include <HTTPClient.h>
#include <Wire.h>
#include <Adafruit_Sensor.h>
#include <Adafruit_BME680.h>

/* ========= WIFI ========= */

const char* ssid = "_HIRALDA_";
const char* password = "**2004##25__";

/* ========= TAGO ========= */

const char* token = "132d7a07-4c99-4130-aab5-974e71ae2582";

/* ========= BME680 ========= */

#define BME680_ADDR 0x76
#define SEALEVELPRESSURE_HPA (1013.25)

Adafruit_BME680 bme;

/* ========= VARIABLES ========= */

float temperature;
float humidity;
float pressure;
float altitude;
float gas_resistance;

void setup() {

  Serial.begin(115200);

  /* ========= I2C ========= */

  Wire.begin(21, 22);

  /* ========= BME680 ========= */

  if (!bme.begin(BME680_ADDR)) {

    Serial.println("ERROR: BME680 no encontrado");

    while (1);
  }

  Serial.println("BME680 detectado");

  bme.setTemperatureOversampling(BME680_OS_8X);
  bme.setHumidityOversampling(BME680_OS_2X);
  bme.setPressureOversampling(BME680_OS_4X);
  bme.setIIRFilterSize(BME680_FILTER_SIZE_3);
  bme.setGasHeater(320, 150);

  /* ========= WIFI ========= */

  WiFi.begin(ssid, password);

  Serial.print("Conectando WiFi");

  while (WiFi.status() != WL_CONNECTED) {

    delay(500);
    Serial.print(".");
  }

  Serial.println("");
  Serial.println("WiFi conectado");
  Serial.print("IP: ");
  Serial.println(WiFi.localIP());
}

void loop() {

  /* ========= LEER SENSOR ========= */

  if (!bme.performReading()) {

    Serial.println("Error al leer BME680");

    delay(2000);
    return;
  }

  temperature = bme.temperature;

  humidity = bme.humidity;

  pressure = bme.pressure / 100.0;

  altitude = bme.readAltitude(SEALEVELPRESSURE_HPA);

  gas_resistance = bme.gas_resistance;

  /* ========= SERIAL ========= */

  Serial.println("========== BME680 ==========");

  Serial.print("Temperatura: ");
  Serial.print(temperature);
  Serial.println(" °C");

  Serial.print("Humedad: ");
  Serial.print(humidity);
  Serial.println(" %");

  Serial.print("Presion: ");
  Serial.print(pressure);
  Serial.println(" hPa");

  Serial.print("Altitud: ");
  Serial.print(altitude);
  Serial.println(" m");

  Serial.print("Gas: ");
  Serial.print(gas_resistance / 1000.0);
  Serial.println(" kOhm");

  Serial.println("============================");

  /* ========= ENVIAR TAGO ========= */

  if (WiFi.status() == WL_CONNECTED) {

    HTTPClient http;

    http.begin("https://api.tago.io/data");

    http.addHeader("Content-Type", "application/json");

    http.addHeader("Device-Token", token);

    String json = "[";

    json += "{";
    json += "\"variable\":\"temperature\",";
    json += "\"value\":" + String(temperature);
    json += "},";

    json += "{";
    json += "\"variable\":\"humidity\",";
    json += "\"value\":" + String(humidity);
    json += "},";

    json += "{";
    json += "\"variable\":\"pressure\",";
    json += "\"value\":" + String(pressure);
    json += "},";

    json += "{";
    json += "\"variable\":\"altitude\",";
    json += "\"value\":" + String(altitude);
    json += "},";

    json += "{";
    json += "\"variable\":\"gas_resistance\",";
    json += "\"value\":" + String(gas_resistance);
    json += "}";

    json += "]";

    int httpResponseCode = http.POST(json);

    Serial.print("Codigo HTTP: ");
    Serial.println(httpResponseCode);

    http.end();

  } else {

    Serial.println("WiFi desconectado");
  }

  delay(5000);
}