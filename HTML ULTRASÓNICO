<!DOCTYPE html>
<html>
<head>
  <title>Dashboard Sensor PRO</title>

  <style>
    body {
      background: linear-gradient(135deg, #0f172a, #020617);
      color: white;
      font-family: Arial;
      text-align: center;
    }

    h1 {
      margin-top: 20px;
      font-size: 28px;
    }

    .card {
      background: #1e293b;
      width: 300px;
      margin: auto;
      padding: 20px;
      border-radius: 20px;
      box-shadow: 0 10px 25px rgba(0,0,0,0.5);
    }

    .barra-container {
      width: 100%;
      height: 30px;
      background: #0f172a;
      border-radius: 20px;
      overflow: hidden;
      margin-top: 20px;
    }

    .barra {
      height: 100%;
      width: 0%;
      background: green;
      transition: 0.4s;
    }

    .estado {
      font-size: 24px;
      margin-top: 15px;
      font-weight: bold;
    }

    .valor {
      font-size: 40px;
      margin-top: 10px;
      color: #38bdf8;
    }

    .circulo {
      width: 120px;
      height: 120px;
      border-radius: 50%;
      margin: 20px auto;
      background: conic-gradient(green 0%, #1e293b 0%);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 20px;
    }
  </style>

</head>

<body>

<h1>Sensor Ultrasónico</h1>

<div class="card">

  <div class="circulo" id="circulo">
    <span id="porcentaje">0%</span>
  </div>

  <div class="valor" id="valor">-- cm</div>

  <div class="barra-container">
    <div class="barra" id="barra"></div>
  </div>

  <div class="estado" id="estado">Cargando...</div>

</div>

<script>
const token = "608ce6c1-05cb-4efc-ba9c-2a6b944b1b0a";

async function actualizar() {
  const res = await fetch("https://api.tago.io/data?query=last_item", {
    headers: { "Device-Token": token }
  });

  const data = await res.json();

  let distancia = data.result[0].value;

  let barra = document.getElementById("barra");
  let estado = document.getElementById("estado");
  let valor = document.getElementById("valor");
  let circulo = document.getElementById("circulo");
  let porcentajeTxt = document.getElementById("porcentaje");

  valor.innerText = distancia + " cm";

  let porcentaje = Math.min((distancia / 100) * 100, 100);

  barra.style.width = porcentaje + "%";
  porcentajeTxt.innerText = Math.round(porcentaje) + "%";

  let color = "green";

  if (distancia > 70) {
    estado.innerText = "LEJOS";
    color = "#22c55e";
  } else if (distancia > 30) {
    estado.innerText = "MEDIO";
    color = "#eab308";
  } else {
    estado.innerText = "CERCA";
    color = "#ef4444";
  }

  barra.style.background = color;

  circulo.style.background =
    `conic-gradient(${color} ${porcentaje}%, #1e293b ${porcentaje}%)`;
}

setInterval(actualizar, 2000);
</script>

</body>
</html>